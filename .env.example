APP_PORT=8080

# --- Database (PostgreSQL) ---
# Two ways to configure the connection. DATABASE_URL takes precedence; if it
# is empty the discrete DB_* vars are assembled into a postgres:// URL.
# The web process owns migrations; start it first so worker sees a ready schema.
# Important: this file contains examples only. The launch scripts no longer
# invent a fallback DSN; set a real reachable database before starting.
#
# Tip: never log the URL itself — config.SafeDSN() redacts the password.
DATABASE_URL=postgres://media_pipeline:media_pipeline@localhost:5432/media_pipeline?sslmode=disable
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=media_pipeline
# DB_USER=media_pipeline
# DB_PASSWORD=media_pipeline
# DB_SSLMODE=disable

# Pool tuning. Sensible defaults are baked in; override only when you have
# benchmarked a reason to.
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_SEC=1800

# --- Test database (used by `go test ./...`) ---
# When set, repository tests create a per-test PostgreSQL schema, run
# migrations into it, and drop it on cleanup. When unset, those tests skip.
# TEST_DATABASE_URL=postgres://media_pipeline:media_pipeline@localhost:5432/media_pipeline_test?sslmode=disable

# --- Storage paths ---
UPLOAD_DIR=./data/uploads
AUTO_UPLOAD_DIR=./data/auto_uploads
AUTO_UPLOAD_ARCHIVE_DIR=./data/auto_uploads_imported
AUDIO_DIR=./data/audio
PREVIEW_DIR=./data/previews
SCREENSHOTS_DIR=./data/screenshots

# --- External binaries ---
FFMPEG_BINARY=ffmpeg
PYTHON_BINARY=python
TRANSCRIBE_SCRIPT=./scripts/transcribe.py
TRANSCRIBE_LANGUAGE=

# --- Limits & timeouts ---
MAX_UPLOAD_SIZE_MB=1024
WORKER_POLL_INTERVAL_MS=2000
AUTO_UPLOAD_MIN_AGE_SEC=60
FFMPEG_TIMEOUT_SEC=120
PREVIEW_TIMEOUT_SEC=600
SCREENSHOT_TIMEOUT_SEC=60
TRANSCRIBE_TIMEOUT_SEC=300

# --- Summarization ---
SUMMARY_PROVIDER=simple
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=phi3:mini

# --- HTTP ---
HTTP_REQUEST_TIMEOUT_SEC=30
UPLOAD_RATE_LIMIT_PER_MINUTE=0
MEDIA_ACCESS_TOKEN=
